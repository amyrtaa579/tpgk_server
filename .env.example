# Application
APP_NAME=Anmicius API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database
POSTGRES_USER=anmicius
POSTGRES_PASSWORD=<your_secure_password_here>
POSTGRES_DB=anmicius_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://anmicius:<your_secure_password_here>@postgres:5432/anmicius_db

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<your_minio_access_key_here>
MINIO_SECRET_KEY=<your_minio_secret_key_here>
MINIO_BUCKET=anmicius-media
MINIO_SECURE=false
MINIO_PUBLIC_URL=https://minio.anmicius.ru/anmicius-media

# CORS
CORS_ORIGINS=https://anmicius.ru,https://api.anmicius.ru,https://minio.anmicius.ru,https://admin.anmicius.ru

# API
API_V1_PREFIX=/api/v1

# JWT - ОБЯЗАТЕЛЬНО установите случайный секретный ключ для production!
# Сгенерировать можно командой: openssl rand -hex 32
JWT_SECRET_KEY=<your_jwt_secret_key_here>

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_DEFAULT=300
REDIS_TTL_LONG=3600

# SSL/HTTPS (опционально, для production)
SSL_EMAIL=your-email@example.com
MAIN_DOMAIN=anmicius.ru
