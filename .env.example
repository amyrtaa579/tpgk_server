# Application
APP_NAME=Anmicius API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database
POSTGRES_USER=anmicius
POSTGRES_PASSWORD=anmicius_secret_password
POSTGRES_DB=anmicius_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://anmicius:anmicius_secret_password@postgres:5432/anmicius_db

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anmicius-media
MINIO_SECURE=false
MINIO_PUBLIC_URL=https://minio.anmicius.ru/anmicius-media

# CORS
CORS_ORIGINS=https://anmicius.ru,https://api.anmicius.ru,https://minio.anmicius.ru,https://admin.anmicius.ru

# API
API_V1_PREFIX=/api/v1

# SSL/HTTPS (опционально, для production)
# SSL_EMAIL=your-email@example.com
# MAIN_DOMAIN=anmicius.ru
